# 环境变量配置模板
# 复制为 .env 并修改实际值

# Admin服务
APP_ADMIN_SERVER_HOST=0.0.0.0
APP_ADMIN_SERVER_PORT=8081
APP_ADMIN_HMAC_SECRET=your-secret-key-change-in-production
APP_ADMIN_SUPER_USER_ID=1001
APP_ADMIN_ACCESS_TOKEN_TTL=3600
APP_ADMIN_REFRESH_TOKEN_TTL=86400

# API服务
APP_API_SERVER_HOST=0.0.0.0
APP_API_SERVER_PORT=8082
APP_API_HMAC_SECRET=api-secret-key-change-in-production
APP_API_ACCESS_TOKEN_TTL=7200
APP_API_REFRESH_TOKEN_TTL=604800

# MySQL
APP_MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/admin?charset=utf8mb4&parseTime=True&loc=Local
APP_MYSQL_PREFIX=admin_

# Redis
APP_REDIS_HOST=127.0.0.1
APP_REDIS_PORT=6379
APP_REDIS_PASSWORD=
APP_REDIS_DB=0

# MongoDB
APP_MONGODB_URI=mongodb://127.0.0.1:27017
APP_MONGODB_DATABASE=admin
APP_MONGODB_ENABLED=false

# 日志
APP_LOGGER_LEVEL=debug
APP_LOGGER_WRITERS=console,file